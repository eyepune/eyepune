# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── LLM API (server-side only — never exposed to client) ─────────────
LLM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
LLM_API_KEY=your-nvidia-api-key-here
LLM_MODEL=qwen/qwen3.5-122b-a10b

# ── Zoho Mail (for transactional emails via Zoho Mail API) ────────────
# Step 1: Go to https://api-console.zoho.in/ → Register as Developer
# Step 2: Create a Server-Side Application client
# Step 3: Add scope: ZohoMail.messages.CREATE
# Step 4: Generate refresh token (see guide)
ZOHO_CLIENT_ID=your-zoho-client-id-here
ZOHO_CLIENT_SECRET=your-zoho-client-secret-here
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token-here
ZOHO_MAIL_ACCOUNT_ID=your-zoho-mail-account-id-here
ZOHO_MAIL_USERNAME=connect@eyepune.com

# ── Razorpay (for payments) ──────────────────────────────────────────
# Step 1: Go to https://dashboard.razorpay.com/ → Settings → API Keys
# Step 2: Generate Key ID and Key Secret
# Step 3: Set up webhook endpoint for payment confirmations
RAZORPAY_KEY_ID=your-razorpay-key-id-here
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# ── Resend (alternative email provider — optional) ────────────────────
RESEND_API_KEY=your-resend-api-key-here

# ── Cloudflare Turnstile (optional, for form protection) ────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
